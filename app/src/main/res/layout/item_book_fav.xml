<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:paddingHorizontal="24dp" android:paddingVertical="16dp" android:background="?android:attr/selectableItemBackground">

    <androidx.cardview.widget.CardView
        android:id="@+id/cardCover"
        android:layout_width="88dp" android:layout_height="128dp" app:cardCornerRadius="8dp"
        app:cardElevation="4dp"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintBottom_toBottomOf="parent">

        <ImageView
            android:id="@+id/imgBookCover"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:scaleType="centerCrop"
            tools:src="@tools:sample/backgrounds/scenic" />
    </androidx.cardview.widget.CardView>

    <TextView
        android:id="@+id/txtBookTitle"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_marginStart="20dp"
        android:layout_marginEnd="8dp"
        android:textSize="20sp" android:textStyle="bold"
        android:textColor="?attr/colorOnSurface"
        android:maxLines="2"
        android:ellipsize="end"
        tools:text="Xa Ngoài Kia Nơi Loài Tôm Hát"
        app:layout_constraintTop_toTopOf="@id/cardCover"
        app:layout_constraintStart_toEndOf="@id/cardCover"
        app:layout_constraintEnd_toStartOf="@id/btnDelete" />

    <TextView
        android:id="@+id/txtAuthor"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_marginTop="6dp"
        android:textSize="16sp" android:textColor="?attr/colorOutline"
        tools:text="Delia Owens"
        app:layout_constraintTop_toBottomOf="@id/txtBookTitle"
        app:layout_constraintStart_toStartOf="@id/txtBookTitle"
        app:layout_constraintEnd_toEndOf="@id/txtBookTitle" />

    <TextView
        android:id="@+id/txtReadingStatus"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_marginTop="12dp"
        android:textSize="14sp" android:textColor="?attr/colorPrimary"
        android:fontFamily="sans-serif-medium"
        tools:text="Đã đọc 6 trang"
        app:layout_constraintTop_toBottomOf="@id/txtAuthor"
        app:layout_constraintStart_toStartOf="@id/txtBookTitle"
        app:layout_constraintEnd_toEndOf="@id/txtBookTitle" />

    <ImageButton
        android:id="@+id/btnDelete"
        android:layout_width="48dp" android:layout_height="48dp"
        android:background="?attr/selectableItemBackgroundBorderless"
        android:src="@android:drawable/ic_menu_delete"
        app:tint="#D32F2F"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintBottom_toBottomOf="parent" />

</androidx.constraintlayout.widget.ConstraintLayout>