<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:id="@+id/reading_root"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/reading_bg">

    <!-- Thanh top bar -->
    <LinearLayout
        android:id="@+id/top_bar"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:paddingHorizontal="20dp"
        android:paddingVertical="14dp"
        android:background="@color/reading_topbar_bg"
        android:elevation="4dp"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent">

        <ImageButton
            android:id="@+id/btn_back"
            android:layout_width="36dp"
            android:layout_height="36dp"
            android:src="@drawable/ic_arrow_back"
            android:background="?android:attr/selectableItemBackgroundBorderless"
            app:tint="@color/reading_text_muted"
            android:contentDescription="Quay lại" />

        <LinearLayout
            android:layout_width="0dp"
            android:layout_weight="1"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:gravity="center"
            android:layout_marginHorizontal="12dp">

            <TextView
                android:id="@+id/tv_chapter_label"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="CHƯƠNG 1"
                android:textSize="10sp"
                android:fontFamily="sans-serif-medium"
                android:letterSpacing="0.14"
                android:textAllCaps="true"
                android:textColor="@color/reading_text_muted" />

            <TextView
                android:id="@+id/tv_book_title"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="The Silent Archive"
                android:textSize="15sp"
                android:textStyle="italic|bold"
                android:textColor="@color/reading_accent" />
        </LinearLayout>

        <ImageButton
            android:id="@+id/btn_menu"
            android:layout_width="36dp"
            android:layout_height="36dp"
            android:src="@drawable/ic_toc"
            android:background="?android:attr/selectableItemBackgroundBorderless"
            app:tint="@color/reading_text_muted"
            android:contentDescription="Mục lục"
            android:layout_marginEnd="4dp" />

        <ImageButton
            android:id="@+id/btn_settings"
            android:layout_width="36dp"
            android:layout_height="36dp"
            android:src="@drawable/ic_settings"
            android:background="?android:attr/selectableItemBackgroundBorderless"
            app:tint="@color/reading_text_muted"
            android:contentDescription="Cài đặt" />
    </LinearLayout>

    <!-- Vùng đọc sách - chứa cả nội dung và nút chuyển trang -->
    <ScrollView
        android:id="@+id/reading_scroll_view"
        android:layout_width="0dp"
        android:layout_height="0dp"
        android:overScrollMode="never"
        android:fillViewport="true"
        app:layout_constraintTop_toBottomOf="@id/top_bar"
        app:layout_constraintBottom_toTopOf="@id/bottom_status_bar"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:paddingHorizontal="24dp"
            android:paddingTop="28dp"
            android:paddingBottom="20dp">

            <!-- Nội dung đọc -->
            <TextView
                android:id="@+id/tv_paragraph_1"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="We are but stewards of these echoes, the Head Librarian had once told him. Elias hadn't understood it then. He was young, obsessed with the digital infinite, the way a billion books could be distilled into a single shard of glass. But as the years turned into a slow, rhythmic dance of cataloging and preservation, he realized that the infinite was often a mask for the empty."
                android:textSize="@dimen/reading_text_size"
                android:lineSpacingMultiplier="1.65"
                android:textColor="@color/reading_text"
                android:layout_marginBottom="@dimen/reading_paragraph_spacing" />

            <LinearLayout
                android:id="@+id/pull_quote_container"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:layout_marginStart="24dp"
                android:layout_marginBottom="@dimen/reading_paragraph_spacing">

                <View
                    android:layout_width="3dp"
                    android:layout_height="match_parent"
                    android:background="@color/reading_accent" />

                <TextView
                    android:id="@+id/tv_pull_quote"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text='"The archive is not a place where things are kept; it is a place where things are allowed to remain."'
                    android:textSize="@dimen/reading_text_size"
                    android:textStyle="italic"
                    android:lineSpacingMultiplier="1.7"
                    android:textColor="@color/reading_text_muted"
                    android:paddingStart="16dp" />
            </LinearLayout>

            <TextView
                android:id="@+id/tv_paragraph_2"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="In the heart of the library, the air smelled of almond and old dust—a scent he had come to associate with truth. There were no search bars here. No algorithms to suggest what he might like next. There was only the weight of the book in his hands and the silence that demanded he listen."
                android:textSize="@dimen/reading_text_size"
                android:lineSpacingMultiplier="1.65"
                android:textColor="@color/reading_text"
                android:layout_marginBottom="@dimen/reading_paragraph_spacing" />

            <TextView
                android:id="@+id/tv_paragraph_3"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="He turned the page. The sound was like a sharp intake of breath in the quiet room. On page eighty-four, he found it. A marginal note, written in a hand so fine it looked like lace. It wasn't a correction or a citation. It was a confession."
                android:textSize="@dimen/reading_text_size"
                android:lineSpacingMultiplier="1.65"
                android:textColor="@color/reading_text"
                android:layout_marginBottom="@dimen/reading_paragraph_spacing" />

            <TextView
                android:id="@+id/tv_paragraph_4"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="The curator leaned closer, the Light Teal glow of his modern interface momentarily forgotten on the desk behind him. He was no longer a man of the modern world; he was a traveler in someone else's memory."
                android:textSize="@dimen/reading_text_size"
                android:lineSpacingMultiplier="1.65"
                android:textColor="@color/reading_text"
                android:layout_marginBottom="@dimen/reading_paragraph_spacing" />

            <TextView
                android:id="@+id/tv_paragraph_5"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="The sun began to dip below the horizon of the city outside, casting long, bruised shadows through the high windows of the archive. Elias did not reach for the light switch. He let the darkness bloom, knowing that some words were only meant to be read in the twilight."
                android:textSize="@dimen/reading_text_size"
                android:lineSpacingMultiplier="1.65"
                android:textColor="@color/reading_text"
                android:layout_marginBottom="24dp" />

            <!-- Thanh chuyển trang - nằm ở cuối mỗi trang đọc -->
            <LinearLayout
                android:id="@+id/bottom_navigation_bar"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical">

                <!-- Nút Trang trước -->
                <Button
                    android:id="@+id/btn_prev_chapter"
                    android:layout_width="0dp"
                    android:layout_weight="1"
                    android:layout_height="44dp"
                    android:text="◀ Trang trước"
                    android:textSize="12sp"
                    android:background="@drawable/reading_btn_bg"
                    android:textColor="@color/reading_text" />

                <!-- Khoảng cách giữa 2 nút -->
                <Space
                    android:layout_width="16dp"
                    android:layout_height="match_parent" />

                <!-- Nút Trang tiếp -->
                <Button
                    android:id="@+id/btn_next_chapter"
                    android:layout_width="0dp"
                    android:layout_weight="1"
                    android:layout_height="44dp"
                    android:text="Trang tiếp ▶"
                    android:textSize="12sp"
                    android:background="@drawable/reading_btn_bg"
                    android:textColor="@color/reading_text" />
            </LinearLayout>
        </LinearLayout>
    </ScrollView>

    <!-- Thanh trạng thái: Trang đang đọc + % hoàn thành (frozen ở cuối) -->
    <LinearLayout
        android:id="@+id/bottom_status_bar"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:paddingHorizontal="24dp"
        android:paddingVertical="12dp"
        android:background="@color/reading_topbar_bg"
        android:elevation="4dp"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent">

        <TextView
            android:id="@+id/tv_page_number"
            android:layout_width="0dp"
            android:layout_weight="1"
            android:layout_height="wrap_content"
            android:text="Trang 1 / 10"
            android:textSize="13sp"
            android:textColor="@color/reading_text_muted" />

        <TextView
            android:id="@+id/tv_progress_percent"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="1%"
            android:textSize="13sp"
            android:textColor="@color/reading_accent" />
    </LinearLayout>

    <!-- Panel cài đặt -->
    <androidx.cardview.widget.CardView
        android:id="@+id/settings_panel"
        android:layout_width="260dp"
        android:layout_height="wrap_content"
        android:layout_marginTop="8dp"
        android:layout_marginEnd="12dp"
        android:visibility="gone"
        android:elevation="12dp"
        app:cardCornerRadius="18dp"
        app:cardBackgroundColor="@color/reading_surface"
        app:layout_constraintTop_toBottomOf="@id/top_bar"
        app:layout_constraintEnd_toEndOf="parent">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="20dp">

            <!-- Độ sáng -->
            <TextView
                style="@style/ReadingSettingsLabel"
                android:text="ĐỘ SÁNG" />
            <SeekBar
                android:id="@+id/slider_brightness"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:max="100"
                android:progress="70"
                android:progressTint="@color/reading_accent"
                android:thumbTint="@color/reading_accent"
                android:layout_marginBottom="20dp" />

            <!-- Cỡ chữ -->
            <TextView
                style="@style/ReadingSettingsLabel"
                android:text="CỠ CHỮ" />
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:layout_marginBottom="20dp">

                <Button
                    android:id="@+id/btn_text_minus"
                    style="@style/ReadingTextSizeBtn"
                    android:text="A−"
                    android:textSize="16sp" />

                <Button
                    android:id="@+id/btn_text_100"
                    style="@style/ReadingTextSizeBtn"
                    android:layout_marginHorizontal="8dp"
                    android:text="100%"
                    android:textSize="13sp" />

                <Button
                    android:id="@+id/btn_text_plus"
                    style="@style/ReadingTextSizeBtn"
                    android:text="A+"
                    android:textSize="16sp" />
            </LinearLayout>

            <!-- Phông chữ -->
            <TextView
                style="@style/ReadingSettingsLabel"
                android:text="PHÔNG CHỮ" />
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:background="@drawable/reading_toggle_bg"
                android:padding="4dp"
                android:layout_marginBottom="20dp">

                <Button
                    android:id="@+id/btn_font_literata"
                    style="@style/ReadingFontBtn"
                    android:text="Literata"
                    android:textStyle="italic" />

                <Button
                    android:id="@+id/btn_font_inter"
                    style="@style/ReadingFontBtn"
                    android:text="Inter Sans" />
            </LinearLayout>

            <!-- Chủ đề -->
            <TextView
                style="@style/ReadingSettingsLabel"
                android:text="CHỦ ĐỀ" />
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal">

                <View
                    android:id="@+id/btn_theme_light"
                    android:layout_width="36dp"
                    android:layout_height="36dp"
                    android:background="@drawable/reading_theme_circle_light"
                    android:layout_marginEnd="12dp" />

                <View
                    android:id="@+id/btn_theme_sepia"
                    android:layout_width="36dp"
                    android:layout_height="36dp"
                    android:background="@drawable/reading_theme_circle_sepia"
                    android:layout_marginEnd="12dp" />

                <View
                    android:id="@+id/btn_theme_dark"
                    android:layout_width="36dp"
                    android:layout_height="36dp"
                    android:background="@drawable/reading_theme_circle_dark" />
            </LinearLayout>
        </LinearLayout>
    </androidx.cardview.widget.CardView>

</androidx.constraintlayout.widget.ConstraintLayout>
