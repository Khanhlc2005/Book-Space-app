<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#FFFFFF"
    tools:context=".MainActivity">

    <!-- ═══════════════════════════════════════════════════════════════
         TOP APP BAR — ghim trên cùng
         ═══════════════════════════════════════════════════════════════ -->
    <LinearLayout
        android:id="@+id/topBar"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:paddingHorizontal="24dp"
        android:paddingVertical="14dp"
        android:gravity="center_vertical"
        android:background="#FFFFFF"
        android:elevation="4dp"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent">

        <ImageView
            android:layout_width="26dp"
            android:layout_height="26dp"
            android:src="@drawable/ic_menu_book"
            app:tint="@color/teal_600"
            android:contentDescription="@string/app_name" />

        <TextView
            android:layout_width="0dp"
            android:layout_weight="1"
            android:layout_height="wrap_content"
            android:text="@string/app_title"
            android:textSize="20sp"
            android:textStyle="bold|italic"
            android:textColor="@color/teal_600"
            android:layout_marginStart="8dp"
            android:letterSpacing="-0.02" />

        <ImageView
            android:id="@+id/btnSearch"
            android:layout_width="40dp"
            android:layout_height="40dp"
            android:padding="8dp"
            android:src="@android:drawable/ic_menu_search"
            app:tint="#476868"
            android:background="?android:attr/selectableItemBackgroundBorderless"
            android:contentDescription="@string/cd_notification" />

        <FrameLayout
            android:layout_width="38dp"
            android:layout_height="38dp"
            android:layout_marginStart="8dp">

            <com.google.android.material.imageview.ShapeableImageView
                android:id="@+id/imgProfile"
                android:layout_width="38dp"
                android:layout_height="38dp"
                android:scaleType="centerCrop"
                android:src="@mipmap/ic_launcher_round"
                app:shapeAppearanceOverlay="@style/CircleImageView"
                android:contentDescription="@string/cd_profile" />

            <View
                android:layout_width="38dp"
                android:layout_height="38dp"
                android:background="@drawable/profile_ring" />
        </FrameLayout>
    </LinearLayout>

    <!-- ═══════════════════════════════════════════════════════════════
         BOTTOM NAVIGATION BAR — ghim dưới cùng
         ═══════════════════════════════════════════════════════════════ -->
    <LinearLayout
        android:id="@+id/bottomNavContainer"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center"
        android:background="@drawable/bottom_nav_bg"
        android:elevation="16dp"
        android:paddingTop="12dp"
        android:paddingBottom="2dp"
        android:paddingHorizontal="16dp"
        android:background="#94F098"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent">

        <!-- HOME (inactive) -->
        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:gravity="center">

            <LinearLayout
                android:id="@+id/nav_home"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:gravity="center"
                android:paddingHorizontal="16dp"
                android:paddingVertical="8dp">

                <ImageView
                    android:layout_width="24dp"
                    android:layout_height="24dp"
                    android:src="@drawable/menu"
                    app:tint="#BDBDBD" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="4dp"
                    android:text="@string/nav_home"
                    android:textColor="#BDBDBD"
                    android:textSize="10sp"
                    android:letterSpacing="0.06"
                    android:fontFamily="sans-serif-medium" />
            </LinearLayout>
        </LinearLayout>

        <!-- READER (active - giữa) -->
        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:gravity="center">

            <LinearLayout
                android:id="@+id/nav_reader"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:gravity="center"
                android:background="@drawable/bottom_nav_active_bg"
                android:paddingHorizontal="20dp"
                android:paddingVertical="10dp">

                <ImageView
                    android:layout_width="26dp"
                    android:layout_height="26dp"
                    android:src="@drawable/menu"
                    app:tint="@color/teal_600" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="4dp"
                    android:text="@string/nav_reader"
                    android:textColor="@color/teal_600"
                    android:textSize="10sp"
                    android:letterSpacing="0.06"
                    android:textStyle="bold"
                    android:fontFamily="sans-serif-medium" />
            </LinearLayout>
        </LinearLayout>

        <!-- LIBRARY (inactive) -->
        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:gravity="center">

            <LinearLayout
                android:id="@+id/nav_library"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:gravity="center"
                android:paddingHorizontal="16dp"
                android:paddingVertical="8dp">

                <ImageView
                    android:layout_width="24dp"
                    android:layout_height="24dp"
                    android:src="@drawable/menu"
                    app:tint="#BDBDBD" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="4dp"
                    android:text="@string/nav_library"
                    android:textColor="#BDBDBD"
                    android:textSize="10sp"
                    android:letterSpacing="0.06"
                    android:fontFamily="sans-serif-medium" />
            </LinearLayout>
        </LinearLayout>

    </LinearLayout>

    <!-- ═══════════════════════════════════════════════════════════════
         SCROLLABLE CONTENT
         — top gắn vào đáy topBar
         — bottom gắn vào đỉnh bottomNavContainer
         ═══════════════════════════════════════════════════════════════ -->
    <androidx.core.widget.NestedScrollView
        android:layout_width="0dp"
        android:layout_height="0dp"
        android:clipToPadding="false"
        android:paddingBottom="16dp"
        android:overScrollMode="never"
        app:layout_constraintTop_toBottomOf="@id/topBar"
        app:layout_constraintBottom_toTopOf="@id/bottomNavContainer"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical">

            <!-- ════════════════════════════════════════════
                 HERO HEADER
                 ════════════════════════════════════════════ -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:paddingHorizontal="24dp"
                android:paddingTop="28dp"
                android:paddingBottom="28dp">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="@string/library_sublabel"
                    android:textSize="12sp"
                    android:textColor="@color/teal_600"
                    android:letterSpacing="0.12"
                    android:textAllCaps="true"
                    android:fontFamily="sans-serif-medium"
                    android:layout_marginBottom="10dp" />

                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="@string/library_hero_title_1"
                    android:textSize="40sp"
                    android:textStyle="bold"
                    android:textColor="#1C1B1F"
                    android:letterSpacing="-0.02" />

                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="@string/library_hero_title_2"
                    android:textSize="40sp"
                    android:textStyle="bold|italic"
                    android:textColor="#1C1B1F"
                    android:letterSpacing="-0.02" />
            </LinearLayout>

            <!-- ════════════════════════════════════════════
                 TAB ROW — gạch chân
                 ════════════════════════════════════════════ -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:paddingHorizontal="24dp"
                android:layout_marginBottom="8dp">

                <LinearLayout
                    android:id="@+id/tabReading"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:layout_marginEnd="32dp">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="@string/tab_reading"
                        android:textSize="16sp"
                        android:textStyle="bold"
                        android:textColor="@color/teal_600"
                        android:paddingBottom="10dp" />

                    <View
                        android:layout_width="match_parent"
                        android:layout_height="3dp"
                        android:background="@color/teal_600" />
                </LinearLayout>

                <LinearLayout
                    android:id="@+id/tabFavorite"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:orientation="vertical">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="@string/tab_favorite"
                        android:textSize="16sp"
                        android:textColor="#BDBDBD"
                        android:fontFamily="sans-serif-medium"
                        android:paddingBottom="10dp" />

                    <View
                        android:layout_width="match_parent"
                        android:layout_height="3dp"
                        android:background="@android:color/transparent" />
                </LinearLayout>
            </LinearLayout>

            <!-- Divider -->
            <View
                android:layout_width="match_parent"
                android:layout_height="1dp"
                android:background="#E0E0E0"
                android:layout_marginBottom="20dp" />

            <!-- ════════════════════════════════════════════
                 BOOK CARD 1
                 ════════════════════════════════════════════ -->
            <androidx.cardview.widget.CardView
                android:id="@+id/cardBook1"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginHorizontal="24dp"
                android:layout_marginBottom="12dp"
                app:cardCornerRadius="16dp"
                app:cardBackgroundColor="#F7F7F7"
                app:cardElevation="0dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:padding="16dp"
                    android:gravity="center_vertical">

                    <androidx.cardview.widget.CardView
                        android:layout_width="80dp"
                        android:layout_height="110dp"
                        app:cardCornerRadius="8dp"
                        app:cardElevation="6dp">

                        <ImageView
                            android:id="@+id/imgBook1"
                            android:layout_width="match_parent"
                            android:layout_height="match_parent"
                            android:scaleType="centerCrop"
                            android:src="@mipmap/ic_launcher"
                            android:contentDescription="@string/cd_book_cover" />
                    </androidx.cardview.widget.CardView>

                    <LinearLayout
                        android:layout_width="0dp"
                        android:layout_weight="1"
                        android:layout_height="wrap_content"
                        android:orientation="vertical"
                        android:layout_marginStart="16dp">

                        <TextView
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:text="@string/book_title_nghe_thuat"
                            android:textSize="17sp"
                            android:textStyle="bold"
                            android:textColor="#1C1B1F"
                            android:maxLines="2"
                            android:ellipsize="end"
                            android:lineSpacingMultiplier="1.2"
                            android:layout_marginBottom="6dp" />

                        <TextView
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:text="@string/book_author_rolf"
                            android:textSize="12sp"
                            android:textColor="#9E9E9E"
                            android:fontFamily="sans-serif-medium"
                            android:textAllCaps="true"
                            android:letterSpacing="0.06"
                            android:layout_marginBottom="18dp" />

                        <LinearLayout
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:orientation="horizontal"
                            android:gravity="center_vertical"
                            android:layout_marginBottom="8dp">

                            <TextView
                                android:layout_width="0dp"
                                android:layout_weight="1"
                                android:layout_height="wrap_content"
                                android:text="TIẾN ĐỘ"
                                android:textSize="11sp"
                                android:textColor="#BDBDBD"
                                android:letterSpacing="0.1"
                                android:fontFamily="sans-serif-medium" />

                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="@string/progress_label_45"
                                android:textSize="12sp"
                                android:textColor="@color/teal_600"
                                android:textStyle="bold" />
                        </LinearLayout>

                        <ProgressBar
                            android:layout_width="match_parent"
                            android:layout_height="5dp"
                            android:progress="45"
                            style="@style/Widget.AppCompat.ProgressBar.Horizontal"
                            android:progressDrawable="@drawable/progress_bar_drawable"
                            android:indeterminate="false" />
                    </LinearLayout>
                </LinearLayout>
            </androidx.cardview.widget.CardView>

            <!-- ════════════════════════════════════════════
                 BOOK CARD 2
                 ════════════════════════════════════════════ -->
            <androidx.cardview.widget.CardView
                android:id="@+id/cardBook2"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginHorizontal="24dp"
                android:layout_marginBottom="12dp"
                app:cardCornerRadius="16dp"
                app:cardBackgroundColor="#F7F7F7"
                app:cardElevation="0dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:padding="16dp"
                    android:gravity="center_vertical">

                    <androidx.cardview.widget.CardView
                        android:layout_width="80dp"
                        android:layout_height="110dp"
                        app:cardCornerRadius="8dp"
                        app:cardElevation="6dp">

                        <ImageView
                            android:id="@+id/imgBook2"
                            android:layout_width="match_parent"
                            android:layout_height="match_parent"
                            android:scaleType="centerCrop"
                            android:src="@mipmap/ic_launcher"
                            android:contentDescription="@string/cd_book_cover" />
                    </androidx.cardview.widget.CardView>

                    <LinearLayout
                        android:layout_width="0dp"
                        android:layout_weight="1"
                        android:layout_height="wrap_content"
                        android:orientation="vertical"
                        android:layout_marginStart="16dp">

                        <TextView
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:text="@string/book_title_suoi_nguon"
                            android:textSize="17sp"
                            android:textStyle="bold"
                            android:textColor="#1C1B1F"
                            android:maxLines="2"
                            android:ellipsize="end"
                            android:lineSpacingMultiplier="1.2"
                            android:layout_marginBottom="6dp" />

                        <TextView
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:text="@string/book_author_ayn"
                            android:textSize="12sp"
                            android:textColor="#9E9E9E"
                            android:fontFamily="sans-serif-medium"
                            android:textAllCaps="true"
                            android:letterSpacing="0.06"
                            android:layout_marginBottom="18dp" />

                        <LinearLayout
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:orientation="horizontal"
                            android:gravity="center_vertical"
                            android:layout_marginBottom="8dp">

                            <TextView
                                android:layout_width="0dp"
                                android:layout_weight="1"
                                android:layout_height="wrap_content"
                                android:text="TIẾN ĐỘ"
                                android:textSize="11sp"
                                android:textColor="#BDBDBD"
                                android:letterSpacing="0.1"
                                android:fontFamily="sans-serif-medium" />

                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="@string/progress_label_12"
                                android:textSize="12sp"
                                android:textColor="@color/teal_600"
                                android:textStyle="bold" />
                        </LinearLayout>

                        <ProgressBar
                            android:layout_width="match_parent"
                            android:layout_height="5dp"
                            android:progress="12"
                            style="@style/Widget.AppCompat.ProgressBar.Horizontal"
                            android:progressDrawable="@drawable/progress_bar_drawable"
                            android:indeterminate="false" />
                    </LinearLayout>
                </LinearLayout>
            </androidx.cardview.widget.CardView>

            <!-- ════════════════════════════════════════════
                 BOOK CARD 3
                 ════════════════════════════════════════════ -->
            <androidx.cardview.widget.CardView
                android:id="@+id/cardBook3"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginHorizontal="24dp"
                android:layout_marginBottom="32dp"
                app:cardCornerRadius="16dp"
                app:cardBackgroundColor="#F7F7F7"
                app:cardElevation="0dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:padding="16dp"
                    android:gravity="center_vertical">

                    <androidx.cardview.widget.CardView
                        android:layout_width="80dp"
                        android:layout_height="110dp"
                        app:cardCornerRadius="8dp"
                        app:cardElevation="6dp">

                        <ImageView
                            android:id="@+id/imgBook3"
                            android:layout_width="match_parent"
                            android:layout_height="match_parent"
                            android:scaleType="centerCrop"
                            android:src="@mipmap/ic_launcher"
                            android:contentDescription="@string/cd_book_cover" />
                    </androidx.cardview.widget.CardView>

                    <LinearLayout
                        android:layout_width="0dp"
                        android:layout_weight="1"
                        android:layout_height="wrap_content"
                        android:orientation="vertical"
                        android:layout_marginStart="16dp">

                        <TextView
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:text="@string/book_title_kafka"
                            android:textSize="17sp"
                            android:textStyle="bold"
                            android:textColor="#1C1B1F"
                            android:maxLines="2"
                            android:ellipsize="end"
                            android:lineSpacingMultiplier="1.2"
                            android:layout_marginBottom="6dp" />

                        <TextView
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:text="@string/book_author_murakami"
                            android:textSize="12sp"
                            android:textColor="#9E9E9E"
                            android:fontFamily="sans-serif-medium"
                            android:textAllCaps="true"
                            android:letterSpacing="0.06"
                            android:layout_marginBottom="18dp" />

                        <LinearLayout
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:orientation="horizontal"
                            android:gravity="center_vertical"
                            android:layout_marginBottom="8dp">

                            <TextView
                                android:layout_width="0dp"
                                android:layout_weight="1"
                                android:layout_height="wrap_content"
                                android:text="TIẾN ĐỘ"
                                android:textSize="11sp"
                                android:textColor="#BDBDBD"
                                android:letterSpacing="0.1"
                                android:fontFamily="sans-serif-medium" />

                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="@string/progress_label_88"
                                android:textSize="12sp"
                                android:textColor="@color/teal_600"
                                android:textStyle="bold" />
                        </LinearLayout>

                        <ProgressBar
                            android:layout_width="match_parent"
                            android:layout_height="5dp"
                            android:progress="88"
                            style="@style/Widget.AppCompat.ProgressBar.Horizontal"
                            android:progressDrawable="@drawable/progress_bar_drawable"
                            android:indeterminate="false" />
                    </LinearLayout>
                </LinearLayout>
            </androidx.cardview.widget.CardView>

            <!-- ════════════════════════════════════════════
                 LỜI TRÍCH HÔM NAY
                 ════════════════════════════════════════════ -->
            <androidx.cardview.widget.CardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginHorizontal="24dp"
                android:layout_marginBottom="32dp"
                app:cardCornerRadius="20dp"
                app:cardBackgroundColor="#F0FAF8"
                app:cardElevation="0dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="24dp">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="✦"
                        android:textSize="24sp"
                        android:textColor="@color/teal_600"
                        android:layout_marginBottom="12dp" />

                    <TextView
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:text="@string/section_quote_title"
                        android:textSize="22sp"
                        android:textStyle="bold"
                        android:textColor="#1C1B1F"
                        android:layout_marginBottom="16dp" />

                    <TextView
                        android:id="@+id/tvQuote"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:text="@string/quote_content"
                        android:textSize="15sp"
                        android:textStyle="italic"
                        android:textColor="#424242"
                        android:lineSpacingMultiplier="1.6"
                        android:layout_marginBottom="20dp" />

                    <View
                        android:layout_width="40dp"
                        android:layout_height="2dp"
                        android:background="@color/teal_600"
                        android:layout_marginBottom="12dp" />

                    <TextView
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:text="@string/quote_source"
                        android:textSize="11sp"
                        android:textColor="@color/teal_600"
                        android:letterSpacing="0.12"
                        android:textAllCaps="true"
                        android:fontFamily="sans-serif-medium" />
                </LinearLayout>
            </androidx.cardview.widget.CardView>

            <!-- ════════════════════════════════════════════
                 THỐNG KÊ ĐỌC
                 ════════════════════════════════════════════ -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:paddingHorizontal="24dp"
                android:paddingBottom="16dp">

                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="@string/section_stats_title"
                    android:textSize="12sp"
                    android:textColor="#9E9E9E"
                    android:letterSpacing="0.12"
                    android:textAllCaps="true"
                    android:fontFamily="sans-serif-medium"
                    android:layout_marginBottom="20dp" />

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal">

                    <LinearLayout
                        android:layout_width="0dp"
                        android:layout_weight="1"
                        android:layout_height="wrap_content"
                        android:orientation="vertical">

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="@string/stat_books_count"
                            android:textSize="48sp"
                            android:textStyle="bold"
                            android:textColor="@color/teal_600"
                            android:letterSpacing="-0.02"
                            android:layout_marginBottom="4dp" />

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="@string/stat_books_label"
                            android:textSize="13sp"
                            android:textColor="#9E9E9E"
                            android:fontFamily="sans-serif-medium" />
                    </LinearLayout>

                    <View
                        android:layout_width="1dp"
                        android:layout_height="60dp"
                        android:background="#E0E0E0"
                        android:layout_gravity="center_vertical"
                        android:layout_marginHorizontal="24dp" />

                    <LinearLayout
                        android:layout_width="0dp"
                        android:layout_weight="1"
                        android:layout_height="wrap_content"
                        android:orientation="vertical">

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="@string/stat_hours_count"
                            android:textSize="48sp"
                            android:textStyle="bold"
                            android:textColor="@color/teal_600"
                            android:letterSpacing="-0.02"
                            android:layout_marginBottom="4dp" />

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="@string/stat_hours_label"
                            android:textSize="13sp"
                            android:textColor="#9E9E9E"
                            android:fontFamily="sans-serif-medium" />
                    </LinearLayout>
                </LinearLayout>
            </LinearLayout>

        </LinearLayout>
    </androidx.core.widget.NestedScrollView>

</androidx.constraintlayout.widget.ConstraintLayout>