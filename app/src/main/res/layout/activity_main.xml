<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/main"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/background"
    tools:context=".MainActivity">

    <!-- ═══════════════════════════════════════════════════════════════
         TOP APP BAR — Glassmorphic style (white 80% + blur)
         ═══════════════════════════════════════════════════════════════ -->
    <LinearLayout
        android:id="@+id/topBar"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:paddingHorizontal="24dp"
        android:paddingVertical="16dp"
        android:gravity="center_vertical"
        android:background="@color/white_80"
        android:elevation="4dp"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent">

        <!-- App Logo Icon -->
        <ImageView
            android:layout_width="28dp"
            android:layout_height="28dp"
            android:src="@drawable/ic_menu_book"
            app:tint="@color/teal_600"
            android:contentDescription="@string/app_name" />

        <!-- App Title -->
        <TextView
            android:layout_width="0dp"
            android:layout_weight="1"
            android:layout_height="wrap_content"
            android:text="@string/app_title"
            android:textSize="24sp"
            android:textStyle="bold|italic"
            android:textColor="@color/primary"
            android:layout_marginStart="8dp"
            android:letterSpacing="-0.02" />

        <!-- Notification Bell -->
        <ImageView
            android:id="@+id/btnNotification"
            android:layout_width="40dp"
            android:layout_height="40dp"
            android:padding="8dp"
            android:src="@drawable/ic_notifications"
            app:tint="#476868"
            android:background="?android:attr/selectableItemBackgroundBorderless"
            android:contentDescription="@string/cd_notification" />

        <!-- User Profile Avatar -->
        <FrameLayout
            android:layout_width="40dp"
            android:layout_height="40dp"
            android:layout_marginStart="12dp">

            <com.google.android.material.imageview.ShapeableImageView
                android:id="@+id/imgProfile"
                android:layout_width="40dp"
                android:layout_height="40dp"
                android:scaleType="centerCrop"
                android:src="@mipmap/ic_launcher_round"
                app:shapeAppearanceOverlay="@style/CircleImageView"
                android:contentDescription="@string/cd_profile" />

            <View
                android:layout_width="40dp"
                android:layout_height="40dp"
                android:background="@drawable/profile_ring" />
        </FrameLayout>
    </LinearLayout>

    <!-- ═══════════════════════════════════════════════════════════════
         SCROLLABLE CONTENT
         ═══════════════════════════════════════════════════════════════ -->
    <androidx.core.widget.NestedScrollView
        android:layout_width="0dp"
        android:layout_height="0dp"
        android:clipToPadding="false"
        android:paddingBottom="100dp"
        android:overScrollMode="never"
        app:layout_constraintTop_toBottomOf="@id/topBar"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:paddingTop="16dp">

            <!-- ════════════════════════════════════════════
                 SEARCH BAR — "Floating" pill style
                 ════════════════════════════════════════════ -->
            <androidx.cardview.widget.CardView
                android:layout_width="match_parent"
                android:layout_height="56dp"
                android:layout_marginHorizontal="24dp"
                android:layout_marginBottom="24dp"
                app:cardCornerRadius="28dp"
                app:cardBackgroundColor="@color/surface_container_highest"
                app:cardElevation="0dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="match_parent"
                    android:gravity="center_vertical"
                    android:orientation="horizontal"
                    android:paddingHorizontal="20dp">

                    <ImageView
                        android:layout_width="24dp"
                        android:layout_height="24dp"
                        android:src="@android:drawable/ic_menu_search"
                        app:tint="@color/outline"
                        android:importantForAccessibility="no" />

                    <EditText
                        android:id="@+id/searchInput"
                        android:layout_width="match_parent"
                        android:layout_height="match_parent"
                        android:background="@null"
                        android:hint="@string/search_hint"
                        android:textColorHint="@color/outline"
                        android:textColor="@color/on_surface"
                        android:textSize="16sp"
                        android:fontFamily="sans-serif-medium"
                        android:layout_marginStart="12dp"
                        android:maxLines="1"
                        android:inputType="text" />
                </LinearLayout>
            </androidx.cardview.widget.CardView>

            <!-- ════════════════════════════════════════════
                 CATEGORY CHIPS — Horizontal scroll
                 ════════════════════════════════════════════ -->
            <HorizontalScrollView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:scrollbars="none"
                android:layout_marginBottom="32dp"
                android:clipToPadding="false"
                android:paddingHorizontal="24dp">

                <LinearLayout
                    android:id="@+id/chipContainer"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:background="@drawable/chip_active_bg"
                        android:text="@string/cat_all"
                        android:textColor="@color/on_primary"
                        android:paddingHorizontal="24dp"
                        android:paddingVertical="10dp"
                        android:textSize="14sp"
                        android:fontFamily="sans-serif-medium" />

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:background="@drawable/chip_bg"
                        android:text="@string/cat_life_skills"
                        android:textColor="@color/on_surface_variant"
                        android:paddingHorizontal="24dp"
                        android:paddingVertical="10dp"
                        android:layout_marginStart="12dp"
                        android:textSize="14sp"
                        android:fontFamily="sans-serif-medium" />

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:background="@drawable/chip_bg"
                        android:text="@string/cat_psychology"
                        android:textColor="@color/on_surface_variant"
                        android:paddingHorizontal="24dp"
                        android:paddingVertical="10dp"
                        android:layout_marginStart="12dp"
                        android:textSize="14sp"
                        android:fontFamily="sans-serif-medium" />

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:background="@drawable/chip_bg"
                        android:text="@string/cat_classic"
                        android:textColor="@color/on_surface_variant"
                        android:paddingHorizontal="24dp"
                        android:paddingVertical="10dp"
                        android:layout_marginStart="12dp"
                        android:textSize="14sp"
                        android:fontFamily="sans-serif-medium" />

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:background="@drawable/chip_bg"
                        android:text="@string/cat_economics"
                        android:textColor="@color/on_surface_variant"
                        android:paddingHorizontal="24dp"
                        android:paddingVertical="10dp"
                        android:layout_marginStart="12dp"
                        android:textSize="14sp"
                        android:fontFamily="sans-serif-medium" />

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:background="@drawable/chip_bg"
                        android:text="@string/cat_literature"
                        android:textColor="@color/on_surface_variant"
                        android:paddingHorizontal="24dp"
                        android:paddingVertical="10dp"
                        android:layout_marginStart="12dp"
                        android:textSize="14sp"
                        android:fontFamily="sans-serif-medium" />
                </LinearLayout>
            </HorizontalScrollView>

            <!-- ════════════════════════════════════════════
                 FEATURED SECTION — ViewPager-style cards
                 ════════════════════════════════════════════ -->
            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="@string/section_featured"
                android:textSize="28sp"
                android:textStyle="bold"
                android:textColor="@color/on_surface"
                android:paddingHorizontal="24dp"
                android:layout_marginBottom="20dp" />

            <HorizontalScrollView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:scrollbars="none"
                android:layout_marginBottom="40dp"
                android:clipToPadding="false"
                android:paddingHorizontal="24dp">

                <LinearLayout
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal">

                    <!-- ── Featured Card 1: Editor's Choice ── -->
                    <FrameLayout
                        android:layout_width="300dp"
                        android:layout_height="240dp"
                        android:layout_marginEnd="16dp">

                        <!-- Gradient Background -->
                        <View
                            android:layout_width="match_parent"
                            android:layout_height="match_parent"
                            android:background="@drawable/featured_card_primary_bg" />

                        <!-- Background Image -->
                        <ImageView
                            android:id="@+id/imgFeatured1"
                            android:layout_width="match_parent"
                            android:layout_height="match_parent"
                            android:scaleType="centerCrop"
                            android:alpha="0.45"
                            android:contentDescription="@string/cd_featured_book" />

                        <!-- Text Content -->
                        <LinearLayout
                            android:layout_width="match_parent"
                            android:layout_height="match_parent"
                            android:orientation="vertical"
                            android:gravity="bottom"
                            android:padding="24dp">

                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="@string/featured_label_editor"
                                android:textColor="@color/white_80"
                                android:textSize="11sp"
                                android:letterSpacing="0.15"
                                android:textAllCaps="true"
                                android:fontFamily="sans-serif-medium"
                                android:layout_marginBottom="8dp" />

                            <TextView
                                android:layout_width="match_parent"
                                android:layout_height="wrap_content"
                                android:text="@string/featured_title_1"
                                android:textColor="@color/on_primary"
                                android:textSize="26sp"
                                android:textStyle="bold"
                                android:lineSpacingMultiplier="1.1"
                                android:layout_marginBottom="8dp" />

                            <TextView
                                android:layout_width="match_parent"
                                android:layout_height="wrap_content"
                                android:text="@string/featured_desc_1"
                                android:textColor="@color/white_90"
                                android:textSize="13sp"
                                android:lineSpacingMultiplier="1.3"
                                android:maxLines="3"
                                android:ellipsize="end" />
                        </LinearLayout>
                    </FrameLayout>

                    <!-- ── Featured Card 2: New Arrival ── -->
                    <FrameLayout
                        android:layout_width="300dp"
                        android:layout_height="240dp">

                        <!-- Gradient Background -->
                        <View
                            android:layout_width="match_parent"
                            android:layout_height="match_parent"
                            android:background="@drawable/featured_card_tertiary_bg" />

                        <!-- Background Image -->
                        <ImageView
                            android:id="@+id/imgFeatured2"
                            android:layout_width="match_parent"
                            android:layout_height="match_parent"
                            android:scaleType="centerCrop"
                            android:alpha="0.40"
                            android:contentDescription="@string/cd_featured_book" />

                        <!-- Text Content -->
                        <LinearLayout
                            android:layout_width="match_parent"
                            android:layout_height="match_parent"
                            android:orientation="vertical"
                            android:gravity="bottom"
                            android:padding="24dp">

                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="@string/featured_label_new"
                                android:textColor="@color/white_80"
                                android:textSize="11sp"
                                android:letterSpacing="0.15"
                                android:textAllCaps="true"
                                android:fontFamily="sans-serif-medium"
                                android:layout_marginBottom="8dp" />

                            <TextView
                                android:layout_width="match_parent"
                                android:layout_height="wrap_content"
                                android:text="@string/featured_title_2"
                                android:textColor="@color/on_tertiary"
                                android:textSize="26sp"
                                android:textStyle="bold"
                                android:lineSpacingMultiplier="1.1"
                                android:layout_marginBottom="8dp" />

                            <TextView
                                android:layout_width="match_parent"
                                android:layout_height="wrap_content"
                                android:text="@string/featured_desc_2"
                                android:textColor="@color/white_90"
                                android:textSize="13sp"
                                android:lineSpacingMultiplier="1.3"
                                android:maxLines="3"
                                android:ellipsize="end" />
                        </LinearLayout>
                    </FrameLayout>
                </LinearLayout>
            </HorizontalScrollView>

            <!-- ════════════════════════════════════════════
                 RECENTLY UPDATED — Section Header + Grid
                 ════════════════════════════════════════════ -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:paddingHorizontal="24dp"
                android:layout_marginBottom="20dp">

                <TextView
                    android:layout_width="0dp"
                    android:layout_weight="1"
                    android:layout_height="wrap_content"
                    android:text="@string/section_recent"
                    android:textSize="28sp"
                    android:textStyle="bold"
                    android:textColor="@color/on_surface" />

                <TextView
                    android:id="@+id/btnSeeAll"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="@string/see_all"
                    android:textSize="14sp"
                    android:textColor="@color/primary"
                    android:fontFamily="sans-serif-medium"
                    android:background="?android:attr/selectableItemBackground"
                    android:paddingHorizontal="4dp"
                    android:paddingVertical="4dp" />
            </LinearLayout>

            <!-- ── Book Grid (2 columns x 2 rows) ── -->
            <GridLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:columnCount="2"
                android:rowCount="2"
                android:paddingHorizontal="24dp"
                android:layout_marginBottom="16dp">

                <!-- ── Book 1: Kiêu hãnh và định kiến ── -->
                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_columnWeight="1"
                    android:orientation="vertical"
                    android:layout_marginEnd="8dp"
                    android:layout_marginBottom="24dp">

                    <androidx.cardview.widget.CardView
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        app:cardCornerRadius="12dp"
                        app:cardBackgroundColor="@color/surface_container_low"
                        app:cardElevation="2dp"
                        android:layout_marginBottom="12dp">

                        <ImageView
                            android:id="@+id/imgBook1"
                            android:layout_width="match_parent"
                            android:layout_height="200dp"
                            android:scaleType="centerCrop"
                            android:background="@drawable/book_cover_bg"
                            android:contentDescription="@string/cd_book_cover" />
                    </androidx.cardview.widget.CardView>

                    <TextView
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:text="@string/book_title_1"
                        android:textSize="16sp"
                        android:textStyle="bold"
                        android:textColor="@color/on_surface"
                        android:maxLines="2"
                        android:ellipsize="end"
                        android:lineSpacingMultiplier="1.15"
                        android:layout_marginBottom="4dp" />

                    <TextView
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:text="@string/book_author_1"
                        android:textSize="13sp"
                        android:textColor="@color/on_surface_variant"
                        android:fontFamily="sans-serif-medium" />
                </LinearLayout>

                <!-- ── Book 2: Chiến tranh và hòa bình ── -->
                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_columnWeight="1"
                    android:orientation="vertical"
                    android:layout_marginStart="8dp"
                    android:layout_marginBottom="24dp">

                    <androidx.cardview.widget.CardView
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        app:cardCornerRadius="12dp"
                        app:cardBackgroundColor="@color/surface_container_low"
                        app:cardElevation="2dp"
                        android:layout_marginBottom="12dp">

                        <ImageView
                            android:id="@+id/imgBook2"
                            android:layout_width="match_parent"
                            android:layout_height="200dp"
                            android:scaleType="centerCrop"
                            android:background="@drawable/book_cover_bg"
                            android:contentDescription="@string/cd_book_cover" />
                    </androidx.cardview.widget.CardView>

                    <TextView
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:text="@string/book_title_2"
                        android:textSize="16sp"
                        android:textStyle="bold"
                        android:textColor="@color/on_surface"
                        android:maxLines="2"
                        android:ellipsize="end"
                        android:lineSpacingMultiplier="1.15"
                        android:layout_marginBottom="4dp" />

                    <TextView
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:text="@string/book_author_2"
                        android:textSize="13sp"
                        android:textColor="@color/on_surface_variant"
                        android:fontFamily="sans-serif-medium" />
                </LinearLayout>

                <!-- ── Book 3: Đắc nhân tâm ── -->
                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_columnWeight="1"
                    android:orientation="vertical"
                    android:layout_marginEnd="8dp"
                    android:layout_marginBottom="24dp">

                    <androidx.cardview.widget.CardView
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        app:cardCornerRadius="12dp"
                        app:cardBackgroundColor="@color/surface_container_low"
                        app:cardElevation="2dp"
                        android:layout_marginBottom="12dp">

                        <ImageView
                            android:id="@+id/imgBook3"
                            android:layout_width="match_parent"
                            android:layout_height="200dp"
                            android:scaleType="centerCrop"
                            android:background="@drawable/book_cover_bg"
                            android:contentDescription="@string/cd_book_cover" />
                    </androidx.cardview.widget.CardView>

                    <TextView
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:text="@string/book_title_3"
                        android:textSize="16sp"
                        android:textStyle="bold"
                        android:textColor="@color/on_surface"
                        android:maxLines="2"
                        android:ellipsize="end"
                        android:lineSpacingMultiplier="1.15"
                        android:layout_marginBottom="4dp" />

                    <TextView
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:text="@string/book_author_3"
                        android:textSize="13sp"
                        android:textColor="@color/on_surface_variant"
                        android:fontFamily="sans-serif-medium" />
                </LinearLayout>

                <!-- ── Book 4: Cội nguồn ── -->
                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_columnWeight="1"
                    android:orientation="vertical"
                    android:layout_marginStart="8dp"
                    android:layout_marginBottom="24dp">

                    <androidx.cardview.widget.CardView
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        app:cardCornerRadius="12dp"
                        app:cardBackgroundColor="@color/surface_container_low"
                        app:cardElevation="2dp"
                        android:layout_marginBottom="12dp">

                        <ImageView
                            android:id="@+id/imgBook4"
                            android:layout_width="match_parent"
                            android:layout_height="200dp"
                            android:scaleType="centerCrop"
                            android:background="@drawable/book_cover_bg"
                            android:contentDescription="@string/cd_book_cover" />
                    </androidx.cardview.widget.CardView>

                    <TextView
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:text="@string/book_title_4"
                        android:textSize="16sp"
                        android:textStyle="bold"
                        android:textColor="@color/on_surface"
                        android:maxLines="2"
                        android:ellipsize="end"
                        android:lineSpacingMultiplier="1.15"
                        android:layout_marginBottom="4dp" />

                    <TextView
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:text="@string/book_author_4"
                        android:textSize="13sp"
                        android:textColor="@color/on_surface_variant"
                        android:fontFamily="sans-serif-medium" />
                </LinearLayout>
            </GridLayout>

        </LinearLayout>

    </androidx.core.widget.NestedScrollView>

    <!-- ═══════════════════════════════════════════════════════════════
         BOTTOM NAVIGATION BAR — Custom Layout to match exact mockup
         ═══════════════════════════════════════════════════════════════ -->
    <LinearLayout
        android:id="@+id/bottomNavContainer"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center"
        android:background="@drawable/bottom_nav_bg"
        android:elevation="16dp"
        android:paddingTop="12dp"
        android:paddingBottom="24dp"
        android:paddingHorizontal="16dp"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent">

        <!-- HOME -->
        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:gravity="center">

            <LinearLayout
                android:id="@+id/nav_home"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:gravity="center"
                android:background="@drawable/bottom_nav_active_bg"
                android:paddingHorizontal="24dp"
                android:paddingVertical="12dp">

                <ImageView
                    android:id="@+id/icon_home"
                    android:layout_width="24dp"
                    android:layout_height="24dp"
                    android:src="@drawable/ic_home_filled"
                    app:tint="@color/teal_600" />

                <TextView
                    android:id="@+id/text_home"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="4dp"
                    android:text="@string/nav_home"
                    android:textColor="@color/teal_600"
                    android:textSize="11sp"
                    android:letterSpacing="0.1"
                    android:textStyle="bold" />
            </LinearLayout>
        </LinearLayout>

        <!-- LIBRARY -->
        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:gravity="center">

            <LinearLayout
                android:id="@+id/nav_library"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:gravity="center"
                android:background="@null"
                android:paddingHorizontal="24dp"
                android:paddingVertical="12dp">

                <ImageView
                    android:id="@+id/icon_library"
                    android:layout_width="24dp"
                    android:layout_height="24dp"
                    android:src="@drawable/ic_library_books"
                    app:tint="#939a9a" />

                <TextView
                    android:id="@+id/text_library"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="4dp"
                    android:text="@string/nav_library"
                    android:textColor="#939a9a"
                    android:textSize="11sp"
                    android:letterSpacing="0.1"
                    android:textStyle="bold" />
            </LinearLayout>
        </LinearLayout>

        <!-- READER -->
        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:gravity="center">

            <LinearLayout
                android:id="@+id/nav_reader"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:gravity="center"
                android:background="@null"
                android:paddingHorizontal="24dp"
                android:paddingVertical="12dp">

                <ImageView
                    android:id="@+id/icon_reader"
                    android:layout_width="24dp"
                    android:layout_height="24dp"
                    android:src="@drawable/ic_auto_stories"
                    app:tint="#939a9a" />

                <TextView
                    android:id="@+id/text_reader"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="4dp"
                    android:text="@string/nav_reader"
                    android:textColor="#939a9a"
                    android:textSize="11sp"
                    android:letterSpacing="0.1"
                    android:textStyle="bold" />
            </LinearLayout>
        </LinearLayout>

    </LinearLayout>

</androidx.constraintlayout.widget.ConstraintLayout>